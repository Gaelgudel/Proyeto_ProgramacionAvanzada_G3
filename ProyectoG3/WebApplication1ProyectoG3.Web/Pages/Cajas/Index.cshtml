@page "{idComercio:int}"
@model ProyectoG3.Web.Pages.Cajas.IndexModel
@{
    ViewData["Title"] = "Cajas del Comercio";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Cajas del Comercio</h2>
        <a asp-page="/Cajas/registrar" asp-route-idComercio="@Model.IdComercio" class="btn btn-primary">
            + Nueva Caja
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Cajas.Any())
    {
        <div class="alert alert-info">No hay cajas registradas para este comercio.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered align-middle">
                <thead class="table">
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Teléfono SINPE</th>
                        <th>Fecha de Registro</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var caja in Model.Cajas)
                    {
                        <tr>
                            <td>@caja.Nombre</td>
                            <td>@(caja.Descripcion.Length > 10 ? caja.Descripcion.Substring(0, 10) + "..." : caja.Descripcion)</td>
                            <td>@caja.TelefonoSINPE</td>
                            <td>@caja.FechaDeRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span class="badge @(caja.Estado ? "bg-success" : "bg-danger")">
                                    @(caja.Estado ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="d-flex gap-1">
                                <a asp-page="/Cajas/Editar" asp-route-id="@caja.IdCaja"
                                   class="btn btn-sm btn-warning">Editar</a>
                                <a asp-page="/Cajas/VerSinpe" asp-route-id="@caja.IdCaja"
                                   class="btn btn-sm btn-info text-white">Ver SINPE</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <a asp-page="/Comercios/Index" class="btn btn-secondary mt-2">← Volver a Comercios</a>
</div>
