@page "{idSinpe:int}"
@model ProyectoG3.Web.Pages.Cajas.AsignarSinpeModel
@{
    ViewData["Title"] = "Asignar SINPE a Caja";
}

<h2>Asignar SINPE a Caja</h2>

<form method="post">
    <input type="hidden" asp-for="IdSinpe" />

    <div class="mb-3">
        <label class="form-label">Seleccionar Caja</label>
        <select asp-for="IdCaja" asp-items="Model.Cajas" class="form-control">
            <option value="">-- Seleccione una caja --</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>

    <a asp-page="VerSinpe" class="btn btn-secondary">
        Cancelar
    </a>
</form>