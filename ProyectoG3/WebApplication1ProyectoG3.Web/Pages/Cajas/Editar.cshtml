@page "{id:int}"
@model ProyectoG3.Web.Pages.Cajas.EditarModel
@{
    ViewData["Title"] = "Editar Caja";
}

<div class="container mt-4" style="max-width:600px;">
    <h2 class="mb-4">Editar Caja</h2>

    <form method="post">
        <input type="hidden" asp-for="Caja.IdCaja" />
        <input type="hidden" asp-for="Caja.IdComercio" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <div class="mb-3">
            <label asp-for="Caja.Nombre" class="form-label fw-semibold">Nombre</label>
            <input asp-for="Caja.Nombre" class="form-control" maxlength="100" />
            <span asp-validation-for="Caja.Nombre" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Caja.Descripcion" class="form-label fw-semibold">Descripción</label>
            <textarea asp-for="Caja.Descripcion" class="form-control" maxlength="150" rows="3"></textarea>
            <span asp-validation-for="Caja.Descripcion" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Caja.TelefonoSINPE" class="form-label fw-semibold">Teléfono SINPE</label>
            <input asp-for="Caja.TelefonoSINPE" class="form-control" maxlength="10" />
            <span asp-validation-for="Caja.TelefonoSINPE" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Caja.Estado" class="form-label fw-semibold">Estado</label>
            <select asp-for="Caja.Estado" class="form-select">
                <option value="true">Activo</option>
                <option value="false">Inactivo</option>
            </select>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
            <a asp-page="Index" asp-route-idComercio="@Model.Caja.IdComercio"
               class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
