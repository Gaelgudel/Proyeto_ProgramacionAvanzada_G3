@page
@model WebApplication1ProyectoG3.Web.Pages.Comercios.IndexModel
@functions {
    string TipoIdentificacionTexto(object tipo)
    {
        int v = (int)tipo;
        return v == 1 ? "Física" : "Jurídica";
    }
    string TipoComercioTexto(object tipo)
    {
        int v = (int)tipo;
        return v switch
        {
            1 => "Restaurantes",
            2 => "Supermercados",
            3 => "Ferreterías",
            _ => "Otros"
        };
    }
}
<h2>Lista de Comercios</h2>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
<p>
    <a asp-page="Create" class="btn btn-primary">Registrar Comercio</a>
</p>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Identificación</th>
            <th>Tipo Identificación</th>
            <th>Nombre</th>
            <th>Tipo Comercio</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Estado</th>
            <th style="width:320px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Comercios == null || !Model.Comercios.Any())
        {
            <tr>
                <td colspan="8" class="text-center">No hay comercios registrados.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Comercios)
            {
                <tr>
                    <td>@item.Identificacion</td>
                    <td>@TipoIdentificacionTexto(item.TipoIdentificacion)</td>
                    <td>@item.Nombre</td>
                    <td>@TipoComercioTexto(item.TipoDeComercio)</td>
                    <td>@item.Telefono</td>
                    <td>@item.CorreoElectronico</td>
                    <td>@(item.Estado ? "Activo" : "Inactivo")</td>
                    <td>
                        <a class="btn btn-sm btn-warning" asp-page="Edit" asp-route-id="@item.IdComercio">Editar</a>
                        <a class="btn btn-sm btn-info" asp-page="Details" asp-route-id="@item.IdComercio">Detalles</a>
                        <a href="/Cajas/Index/@item.IdComercio" class="btn btn-sm btn-success">
                            Ver Cajas
                        </a>
                        <a asp-page="/ConfiguracionComercio/Index"
                           asp-route-idComercio="@item.IdComercio"
                           class="btn btn-sm btn-secondary">
                            Configuración
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>