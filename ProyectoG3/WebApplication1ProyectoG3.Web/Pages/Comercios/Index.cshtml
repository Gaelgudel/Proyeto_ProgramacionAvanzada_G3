@page
@model WebApplication1ProyectoG3.Web.Pages.Comercios.IndexModel

@functions {
    string TipoIdentificacionProsa(object tipo)
    {
        // tipo viene como enum, lo convertimos a int
        int v = (int)tipo;
        return v == 1 ? "Física" : "Jurídica";
    }

    string TipoComercioProsa(object tipo)
    {
        int v = (int)tipo;
        return v switch
        {
            1 => "Restaurantes",
            2 => "Supermercados",
            3 => "Ferreterías",
            _ => "Otros"
        };
    }
}

<h2>Lista de Comercios</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p>
    <a asp-page="Create" class="btn btn-primary">Registrar Comercio</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Identificación</th>
            <th>Tipo Identificación</th>
            <th>Nombre</th>
            <th>Tipo Comercio</th>
            <th>Teléfono</th>
            <th>Correo</th>
            <th>Estado</th>
            <th style="width:260px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Comercios == null || !Model.Comercios.Any())
        {
            <tr>
                <td colspan="8" class="text-center">No hay comercios registrados.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Comercios)
            {
                <tr>
                    <td>@item.Identificacion</td>
                    <td>@TipoIdentificacionProsa(item.TipoIdentificacion)</td>
                    <td>@item.Nombre</td>
                    <td>@TipoComercioProsa(item.TipoDeComercio)</td>
                    <td>@item.Telefono</td>
                    <td>@item.CorreoElectronico</td>
                    <td>@(item.Estado ? "Activo" : "Inactivo")</td>
                    <td>
                        <a class="btn btn-sm btn-warning" asp-page="Edit" asp-route-id="@item.IdComercio">Editar</a>
                        <a class="btn btn-sm btn-info" asp-page="Details" asp-route-id="@item.IdComercio">Detalles</a>
                        <!-- Placeholder: si aún no existe el módulo de Cajas -->
                        <a class="btn btn-sm btn-secondary" href="#">Ver cajas</a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>