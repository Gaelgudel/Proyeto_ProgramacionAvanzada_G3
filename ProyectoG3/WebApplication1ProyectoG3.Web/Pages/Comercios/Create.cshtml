@page
@model WebApplication1ProyectoG3.Web.Pages.Comercios.CreateModel

@functions {
    string TipoIdentificacionProsa(object tipo)
    {
        int v = (int)tipo;
        return v == 1 ? "Física" : "Jurídica";
    }

    string TipoComercioProsa(object tipo)
    {
        int v = (int)tipo;
        return v switch
        {
            1 => "Restaurantes",
            2 => "Supermercados",
            3 => "Ferreterías",
            _ => "Otros"
        };
    }
}

<h2>Registrar Comercio</h2>

<div class="text-danger">
    @Html.ValidationSummary()
</div>

<form method="post">
    <div class="mb-3">
        <label class="form-label">Identificación</label>
        <input asp-for="Comercio.Identificacion" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Tipo Identificación</label>
        <select asp-for="Comercio.TipoIdentificacion" class="form-control" required>
            @foreach (var tipo in Model.TiposIdentificacion)
            {
                <option value="@tipo">@TipoIdentificacionProsa(tipo)</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input asp-for="Comercio.Nombre" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Tipo de Comercio</label>
        <select asp-for="Comercio.TipoDeComercio" class="form-control" required>
            @foreach (var tipo in Model.TiposComercio)
            {
                <option value="@tipo">@TipoComercioProsa(tipo)</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Teléfono</label>
        <input asp-for="Comercio.Telefono" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Correo</label>
        <input asp-for="Comercio.CorreoElectronico" type="email" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Dirección</label>
        <input asp-for="Comercio.Direccion" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-page="Index" class="btn btn-secondary">Volver</a>
</form>