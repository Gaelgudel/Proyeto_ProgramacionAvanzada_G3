@page
@model WebApplication1ProyectoG3.Web.Pages.Comercios.CreateModel

@functions {
    string TipoIdentificacionTexto(object tipo)
    {
        int v = (int)tipo;
        return v == 1 ? "Física" : "Jurídica";
    }

    string TipoComercioTexto(object tipo)
    {
        int v = (int)tipo;
        return v switch
        {
            1 => "Restaurantes",
            2 => "Supermercados",
            3 => "Ferreterías",
            _ => "Otros"
        };
    }
}

<h2>Registrar Comercio</h2>

<div class="text-danger" role="alert">
    @Html.ValidationSummary()
</div>

<form method="post">

    <div class="mb-3">
        <label asp-for="Comercio.Identificacion" class="form-label"></label>

        <input asp-for="Comercio.Identificacion"
               class="form-control"
               required
               aria-required="true"
               aria-describedby="identificacionHelp identificacionError" />

        <small id="identificacionHelp" class="form-text text-muted">
            Ingrese la identificación del comercio
        </small>

        <span asp-validation-for="Comercio.Identificacion"
              id="identificacionError"
              class="text-danger"
              role="alert">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="Comercio.TipoIdentificacion" class="form-label"></label>

        <select asp-for="Comercio.TipoIdentificacion"
                class="form-control"
                required
                aria-required="true"
                aria-describedby="tipoIdHelp">

            @foreach (var tipo in Model.TiposIdentificacion)
            {
                <option value="@tipo">@TipoIdentificacionTexto(tipo)</option>
            }
        </select>

        <small id="tipoIdHelp" class="form-text text-muted">
            Seleccione si el comercio es físico o jurídico
        </small>
    </div>

    <div class="mb-3">
        <label asp-for="Comercio.Nombre" class="form-label"></label>

        <input asp-for="Comercio.Nombre"
               class="form-control"
               required
               aria-required="true"
               aria-describedby="nombreHelp nombreError" />

        <small id="nombreHelp" class="form-text text-muted">
            Ingrese el nombre del comercio
        </small>

        <span asp-validation-for="Comercio.Nombre"
              id="nombreError"
              class="text-danger"
              role="alert">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="Comercio.TipoDeComercio" class="form-label"></label>

        <select asp-for="Comercio.TipoDeComercio"
                class="form-control"
                required
                aria-required="true"
                aria-describedby="tipoComercioHelp">

            @foreach (var tipo in Model.TiposComercio)
            {
                <option value="@tipo">@TipoComercioTexto(tipo)</option>
            }
        </select>

        <small id="tipoComercioHelp" class="form-text text-muted">
            Seleccione el tipo de comercio
        </small>
    </div>

    <div class="mb-3">
        <label asp-for="Comercio.Telefono" class="form-label"></label>

        <input asp-for="Comercio.Telefono"
               class="form-control"
               required
               aria-required="true"
               aria-describedby="telefonoHelp telefonoError" />

        <small id="telefonoHelp" class="form-text text-muted">
            Ingrese un número telefónico válido
        </small>

        <span asp-validation-for="Comercio.Telefono"
              id="telefonoError"
              class="text-danger"
              role="alert">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="Comercio.CorreoElectronico" class="form-label"></label>

        <input asp-for="Comercio.CorreoElectronico"
               type="email"
               class="form-control"
               required
               aria-required="true"
               aria-describedby="correoHelp correoError" />

        <small id="correoHelp" class="form-text text-muted">
            Ingrese un correo electrónico válido
        </small>

        <span asp-validation-for="Comercio.CorreoElectronico"
              id="correoError"
              class="text-danger"
              role="alert">
        </span>
    </div>

    <div class="mb-3">
        <label asp-for="Comercio.Direccion" class="form-label"></label>

        <input asp-for="Comercio.Direccion"
               class="form-control"
               required
               aria-required="true"
               aria-describedby="direccionHelp direccionError" />

        <small id="direccionHelp" class="form-text text-muted">
            Ingrese la dirección del comercio
        </small>

        <span asp-validation-for="Comercio.Direccion"
              id="direccionError"
              class="text-danger"
              role="alert">
        </span>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-page="Index" class="btn btn-secondary">Volver</a>
</form>