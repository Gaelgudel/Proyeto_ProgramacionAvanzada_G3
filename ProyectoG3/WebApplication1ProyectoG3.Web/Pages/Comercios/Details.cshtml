@page "{id:int}"
@model WebApplication1ProyectoG3.Web.Pages.Comercios.DetailsModel

@functions {
    string TipoIdentificacionProsa(object tipo)
    {
        int v = (int)tipo;
        return v == 1 ? "Física" : "Jurídica";
    }

    string TipoComercioProsa(object tipo)
    {
        int v = (int)tipo;
        return v switch
        {
            1 => "Restaurantes",
            2 => "Supermercados",
            3 => "Ferreterías",
            _ => "Otros"
        };
    }
}

<h2>Detalles del Comercio</h2>

@if (Model.Comercio == null)
{
    <div class="alert alert-danger">No se encontró el comercio.</div>
    <a asp-page="Index" class="btn btn-secondary">Volver</a>
}
else
{
    <dl class="row">
        <dt class="col-sm-3">Identificación</dt>
        <dd class="col-sm-9">@Model.Comercio.Identificacion</dd>

        <dt class="col-sm-3">Tipo Identificación</dt>
        <dd class="col-sm-9">@TipoIdentificacionProsa(Model.Comercio.TipoIdentificacion)</dd>

        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Comercio.Nombre</dd>

        <dt class="col-sm-3">Tipo Comercio</dt>
        <dd class="col-sm-9">@TipoComercioProsa(Model.Comercio.TipoDeComercio)</dd>

        <dt class="col-sm-3">Teléfono</dt>
        <dd class="col-sm-9">@Model.Comercio.Telefono</dd>

        <dt class="col-sm-3">Correo</dt>
        <dd class="col-sm-9">@Model.Comercio.CorreoElectronico</dd>

        <dt class="col-sm-3">Dirección</dt>
        <dd class="col-sm-9">@Model.Comercio.Direccion</dd>

        <dt class="col-sm-3">Fecha Registro</dt>
        <dd class="col-sm-9">@Model.Comercio.FechaDeRegistro</dd>

        <dt class="col-sm-3">Fecha Modificación</dt>
        <dd class="col-sm-9">@Model.Comercio.FechaDeModificacion</dd>

        <dt class="col-sm-3">Estado</dt>
        <dd class="col-sm-9">@(Model.Comercio.Estado ? "Activo" : "Inactivo")</dd>
    </dl>

    <a asp-page="Edit" asp-route-id="@Model.Comercio.IdComercio" class="btn btn-primary">Editar</a>
    <a asp-page="Index" class="btn btn-secondary">Volver</a>
}