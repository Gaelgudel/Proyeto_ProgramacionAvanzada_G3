@page
@model ProyectoG3.Web.Pages.Reportes.IndexModel
@{
    ViewData["Title"] = "Reportes Mensuales";
}

<h1 class="mb-4">Reportes Mensuales</h1>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

<form method="post" asp-page-handler="Generar" class="mb-4">
    <button type="submit" class="btn btn-primary">Generar reportes</button>
</form>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Nombre del comercio</th>
            <th>Cantidad de cajas</th>
            <th>Monto recaudado</th>
            <th>Cantidad de SINPES</th>
            <th>Monto total de comisión</th>
            <th>Fecha del reporte</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Reportes != null && Model.Reportes.Any())
        {
            @foreach (var item in Model.Reportes)
            {
                <tr>
                    <td>@item.NombreComercio</td>
                    <td>@item.CantidadDeCajas</td>
                    <td>@item.MontoTotalRecaudado.ToString("C")</td>
                    <td>@item.CantidadDeSINPES</td>
                    <td>@item.MontoTotalComision.ToString("C")</td>
                    <td>@item.FechaDelReporte.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center">No hay reportes generados.</td>
            </tr>
        }
    </tbody>
</table>