<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication1ProyectoG3.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1ProyectoG3.Web.styles.css" asp-append-version="true" />

    <style>
            /* Claro*/
            :root {
                --bg: #ffffff;
                --texto: #212529;
                --muted: #6c757d;
                --btn-tema-bg: #212529;
                --btn-tema-text: #ffffff;
            }

            /* Oscuro*/
            body.dark-mode {
                --bg: #1a1a2e;
                --texto: #e0e0e0;
                --muted: #a0a0b0;
                --btn-tema-bg: #e0e0e0;
                --btn-tema-text: #1a1a2e;
            }

            body {
                background-color: var(--bg) !important;
                color: var(--texto) !important;
                transition: background-color 0.3s ease, color 0.3s ease;
            }

                body.dark-mode .text-muted {
                    color: var(--muted) !important;
                }

                body.dark-mode .table {
                    color: var(--texto) !important;
                }

                    body.dark-mode .table thead th {
                        background-color: #252545 !important;
                        color: #e0e0e0 !important;
                        border-color: #3a3a5c !important;
                    }

                    body.dark-mode .table td,
                    body.dark-mode .table th {
                        color: #e0e0e0 !important;
                        border-color: #3a3a5c !important;
                    }

                body.dark-mode .table-striped > tbody > tr:nth-of-type(odd) > * {
                    background-color: #252545 !important;
                    color: #e0e0e0 !important;
                }

                body.dark-mode .navbar {
                    background-color: #12122a !important;
                }

                body.dark-mode .nav-link,
                body.dark-mode .navbar-brand {
                    color: #e0e0e0 !important;
                }

            /* Boton */
            #btn-tema {
                background-color: var(--btn-tema-bg);
                color: var(--btn-tema-text);
                border: none;
                border-radius: 6px;
                padding: 4px 12px;
                font-size: 0.85rem;
                cursor: pointer;
                transition: background-color 0.3s, color 0.3s;
            }
    </style>

</head>
<body>

    <!--todos los botones juntos-->
    <div class="d-flex justify-content-end align-items-center gap-2 px-3 py-2">

        <span style="font-size:0.82rem; color:var(--muted);">Texto:</span>

        <button id="btnDisminuir" class="btn btn-sm btn-secondary"
                aria-label="Disminuir tamaño de fuente">
            A−
        </button>

        <span id="lblFuente" style="font-size:0.82rem; min-width:38px; text-align:center;">100%</span>

        <button id="btnAumentar" class="btn btn-sm btn-primary"
                aria-label="Aumentar tamaño de fuente">
            A+
        </button>

        <button id="btn-tema"
                aria-pressed="false"
                aria-label="Activar modo oscuro">
             Modo Oscuro
        </button>

    </div>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">WebApplication1ProyectoG3.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebApplication1ProyectoG3.Web - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Llamado de accesibilidad -->
    <script src="~/js/accesibilidad.js"></script>


    <script>
    $(function () {

    const Modelo = {
    tema:     localStorage.getItem('tema')     || 'claro',
    fontSize: parseInt(localStorage.getItem('fontSize')) || 100,
    guardar() {
    localStorage.setItem('tema',     this.tema);
    localStorage.setItem('fontSize', this.fontSize);
    }
    };


    const Vista = {
    aplicarTema(tema) {
    if (tema === 'oscuro') {
    $('body').addClass('dark-mode');
    $('#btn-tema').attr('aria-pressed', 'true')
    .attr('aria-label', 'Activar modo claro')
    .text(' Modo Claro');
    } else {
    $('body').removeClass('dark-mode');
    $('#btn-tema').attr('aria-pressed', 'false')
    .attr('aria-label', 'Activar modo oscuro')
    .text(' Modo Oscuro');
    }
    },
    aplicarFuente(size) {
    $('html').css('font-size', size + '%');
    $('#lblFuente').text(size + '%');
    $('#btnDisminuir').prop('disabled', size <= 80);
    $('#btnAumentar').prop('disabled',  size >= 160);
    }
    };


    const Controlador = {
    init() {
    Vista.aplicarTema(Modelo.tema);
    Vista.aplicarFuente(Modelo.fontSize);

    $('#btn-tema').on('click', function () {
    Modelo.tema = Modelo.tema === 'claro' ? 'oscuro' : 'claro';
    Vista.aplicarTema(Modelo.tema);
    Modelo.guardar();
    });

    $('#btnAumentar').on('click', function () {
    if (Modelo.fontSize >= 160) return;
    Modelo.fontSize += 10;
    Vista.aplicarFuente(Modelo.fontSize);
    Modelo.guardar();
    });

    $('#btnDisminuir').on('click', function () {
    if (Modelo.fontSize <= 80) return;
    Modelo.fontSize -= 10;
    Vista.aplicarFuente(Modelo.fontSize);
    Modelo.guardar();
    });

    // Atajo de teclado Alt+D 
        $(document).on('keydown', function (e) {
        if (e.altKey && e.key.toLowerCase() === 'd') {
        e.preventDefault();
        $('#btn-tema').trigger('click');
        }
        });
        }
        };

        Controlador.init();
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>