<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication1ProyectoG3.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1ProyectoG3.Web.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- Botones cambio tamaño letra -->
    <div style="position: fixed; top: 10px; right: 10px; z-index: 9999;">
        <button id="btnAumentar" class="btn btn-sm btn-primary">A+</button>
        <button id="btnDisminuir" class="btn btn-sm btn-secondary">A-</button>
    </div>

    <header>
        <style>

                    :root {
                        --bg: #ffffff;
                        --texto: #212529;
                        --muted: #6c757d;
                        --hr: #dee2e6;
                        --btn-tema-bg: #212529;
                        --btn-tema-text: #ffffff;
                    }

                    body.dark-mode {
                        --bg: #1a1a2e;
                        --texto: #e0e0e0;
                        --muted: #a0a0b0;
                        --hr: #2e2e4e;
                        --btn-tema-bg: #e0e0e0;
                        --btn-tema-text: #1a1a2e;
                    }

                    body {
                        background-color: var(--bg) !important;
                        color: var(--texto) !important;
                        transition: background-color 0.3s ease, color 0.3s ease;
                    }

                    hr {
                        border-color: var(--hr) !important;
                        transition: border-color 0.3s ease;
                    }

                    body.dark-mode .text-muted {
                        color: var(--muted) !important;
                    }

                    body.dark-mode .btn-outline-primary {
                        color: #7eb8f7;
                        border-color: #7eb8f7;
                    }

                        body.dark-mode .btn-outline-primary:hover {
                            background-color: #7eb8f7;
                            color: #1a1a2e;
                        }

                    body.dark-mode .btn-outline-secondary {
                        color: #a0a0b0;
                        border-color: #a0a0b0;
                    }

                        body.dark-mode .btn-outline-secondary:hover {
                            background-color: #a0a0b0;
                            color: #1a1a2e;
                        }

                    /*Botón de tema*/
                    #btn-tema {
                        background-color: var(--btn-tema-bg);
                        color: var(--btn-tema-text);
                        border: none;
                        border-radius: 40px;
                        padding: 0.4rem 1rem;
                        font-size: 0.875rem;
                        cursor: pointer;
                        transition: background-color 0.3s ease, color 0.3s ease;
                    }

                        #btn-tema:focus-visible {
                            outline: 3px solid #0d6efd;
                            outline-offset: 3px;
                        }

        </style>

        <div id="anunciador"
             role="status"
             aria-live="polite"
             aria-atomic="true"
             style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);">
        </div>


        <div class="d-flex justify-content-end px-3 pt-3">
            <button id="btn-tema"
                    aria-pressed="false"
                    aria-label="Activar modo oscuro">
                Modo Oscuro
            </button>
        </div>


        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
        <script>
            $(function () {


            const Modelo = {
            tema: localStorage.getItem('tema') || 'claro',

            guardar() {
            localStorage.setItem('tema', this.tema);
            }
            };


            const Vista = {

            aplicarTema(tema) {
            if (tema === 'oscuro') {

     
            $('body').addClass('dark-mode');

            $('#btn-tema')
            .attr('aria-pressed', 'true')
            .attr('aria-label',   'Activar modo claro')
            .text(' Modo Claro');

            } else {

            //vuelve al tema claro cuando quita la clase
            $('body').removeClass('dark-mode');

            // Actualiza el botón
            $('#btn-tema')
            .attr('aria-pressed', 'false')
            .attr('aria-label',   'Activar modo oscuro')
            .text(' Modo Oscuro');
            }
            },

            //W3C WAI-ARIA aria-live)
            anunciar(mensaje) {
            $('#anunciador').text('');
            setTimeout(() => $('#anunciador').text(mensaje), 50);
            }
            };


      
            const Controlador = {

            init() {

            Vista.aplicarTema(Modelo.tema);

            $('#btn-tema').on('click', function () {

            Modelo.tema = (Modelo.tema === 'claro') ? 'oscuro' : 'claro';

            Vista.aplicarTema(Modelo.tema);

            Vista.anunciar(
            Modelo.tema === 'oscuro'
            ? 'Modo oscuro activado'
            : 'Modo claro activado'
            );

            Modelo.guardar();
            });

            //  Atajo de teclado: Alt + D
            $(document).on('keydown', function (e) {
            if (e.altKey && e.key.toLowerCase() === 'd') {
            e.preventDefault();
            $('#btn-tema').trigger('click');
            }
            });
            }
            };
            Controlador.init();

            });

        </script>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">WebApplication1ProyectoG3.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ProyectoG3.Web - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Llamado de accesibilidad -->
    <script src="~/js/accesibilidad.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>