@page
@model ProyectoG3.Web.Pages.SINPE.RegistrarModel

<h2>Registrar Pago SINPE</h2>

<form method="post">

    <div class="form-group">
        <label>Teléfono Origen</label>
        <input asp-for="Sinpe.TelefonoOrigen" class="form-control" />
        <span asp-validation-for="Sinpe.TelefonoOrigen" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Nombre Origen</label>
        <input asp-for="Sinpe.NombreOrigen" class="form-control" />
        <span asp-validation-for="Sinpe.NombreOrigen" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Teléfono Destinatario</label>
        <input asp-for="Sinpe.TelefonoDestinatario" class="form-control" />
        <span asp-validation-for="Sinpe.TelefonoDestinatario" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Nombre Destinatario</label>
        <input asp-for="Sinpe.NombreDestinatario" class="form-control" />
        <span asp-validation-for="Sinpe.NombreDestinatario" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Monto</label>
        <input asp-for="Sinpe.Monto" class="form-control" />
        <span asp-validation-for="Sinpe.Monto" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Descripción</label>
        <input asp-for="Sinpe.Descripcion" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Registrar Pago</button>

</form>                                                   -