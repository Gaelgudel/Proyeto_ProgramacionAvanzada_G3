@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<style>
    .dashboard-title {
        font-family: 'Nunito', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .dashboard-subtitle {
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 32px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }

    .stat-card {
        background: var(--bg-card);
        border-radius: 16px;
        padding: 24px;
        position: relative;
        overflow: hidden;
        border: 1px solid var(--border);
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: -24px;
            right: -24px;
            width: 90px;
            height: 90px;
            border-radius: 50%;
            opacity: 0.08;
        }

        .stat-card.red::before {
            background: #e94560;
        }

        .stat-card.blue::before {
            background: #0f3460;
        }

        .stat-card.green::before {
            background: #06d6a0;
        }

        .stat-card.amber::before {
            background: #f5a623;
        }

        .stat-card.purple::before {
            background: #7c3aed;
        }

        .stat-card.teal::before {
            background: #0891b2;
        }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

        .stat-icon.red {
            background: rgba(233,69,96,0.12);
        }

        .stat-icon.blue {
            background: rgba(15,52,96,0.12);
        }

        .stat-icon.green {
            background: rgba(6,214,160,0.12);
        }

        .stat-icon.amber {
            background: rgba(245,166,35,0.12);
        }

        .stat-icon.purple {
            background: rgba(124,58,237,0.12);
        }

        .stat-icon.teal {
            background: rgba(8,145,178,0.12);
        }

        .stat-icon svg {
            width: 22px;
            height: 22px;
        }

        .stat-icon.red svg {
            stroke: #e94560;
        }

        .stat-icon.blue svg {
            stroke: #0f3460;
        }

        .stat-icon.green svg {
            stroke: #06d6a0;
        }

        .stat-icon.amber svg {
            stroke: #f5a623;
        }

        .stat-icon.purple svg {
            stroke: #7c3aed;
        }

        .stat-icon.teal svg {
            stroke: #0891b2;
        }

    .stat-label {
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        margin-bottom: 6px;
    }

    .stat-value {
        font-family: 'Nunito', sans-serif;
        font-size: 36px;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1;
    }

    .modules-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 32px;
    }

    .module-card {
        background: var(--bg-card);
        border-radius: 14px;
        padding: 20px;
        text-decoration: none;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 14px;
        transition: all 0.2s;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }

        .module-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(233,69,96,0.15);
            border-color: rgba(233,69,96,0.3);
            text-decoration: none;
        }

    .module-icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        background: linear-gradient(135deg, #e94560, #c62a47);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .module-icon svg {
            width: 22px;
            height: 22px;
            stroke: #fff;
        }

    .module-name {
        font-family: 'Nunito', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 2px;
    }

    .module-desc {
        font-size: 12px;
        color: var(--text-muted);
    }

    .footer-info {
        text-align: center;
        padding: 20px;
        font-size: 13px;
        color: var(--text-muted);
        background: var(--bg-card);
        border-radius: 14px;
        border: 1px solid var(--border);
    }

    @@media (max-width: 900px) {
        .stats-grid, .modules-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 600px) {
        .stats-grid, .modules-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dashboard-title">Bienvenido a SINPE <span style="color: var(--accent);">G3</span></div>
<div class="dashboard-subtitle">Panel de control — Programación Avanzada 2026</div>

