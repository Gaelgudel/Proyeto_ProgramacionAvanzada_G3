@model IEnumerable<Caja>

<h2>Listado de Cajas</h2>

<a asp-action="Registrar" asp-route-idComercio="@ViewBag.IdComercio"
   class="btn btn-success mb-3">
    Registrar Nueva Caja
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Teléfono SINPE</th>
            <th>Fecha Registro</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var caja in Model)
        {
            <tr>
                <td>@caja.Nombre</td>
                <td>@caja.Descripcion</td>
                <td>@caja.TelefonoSINPE</td>
                <td>@caja.FechaDeRegistro.ToString("dd/MM/yyyy")</td>
                <td>
                    @(caja.Estado ? "Activo" : "Inactivo")
                </td>
                <td>
                    <a asp-action="Editar" asp-route-id="@caja.IdCaja"
                       class="btn btn-primary btn-sm">
                        Editar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>