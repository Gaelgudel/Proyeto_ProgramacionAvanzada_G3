@model Caja

<h2>Registrar Nueva Caja</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form asp-action="Registrar" method="post">

    <input type="hidden" asp-for="IdComercio" />

    <div class="mb-3">
        <label class="form-label">Nombre:</label>
        <input asp-for="Nombre" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Descripción:</label>
        <textarea asp-for="Descripcion" class="form-control" required></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Teléfono SINPE:</label>
        <input asp-for="TelefonoSINPE"
               class="form-control"
               maxlength="10"
               pattern="[0-9]{8,10}"
               required />
    </div>

    <button type="submit" class="btn btn-success">
        Guardar Caja
    </button>

    <a asp-action="VerCajas" asp-route-idComercio="@Model.IdComercio"
       class="btn btn-secondary">
        Volver
    </a>
</form>